<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<!--
    PostMapper.xml

    规则：
      - 顶部 <mapper namespace="..."> 必须等于 PostMapper.java 的全限定名。
      - <select|insert|update|delete> 的 id 必须等于接口里的方法名。
      - application.properties 里开了 map-underscore-to-camel-case=true，
        所以下划线列名会自动映射到驼峰字段，不用手写 <resultMap>。

    已写好 selectById 作为参考；其它 SQL 照着这个格式补充。
-->
<mapper namespace="com.nailong.gengdirection.post.mapper.PostMapper">

    <!-- 公共列：复用，避免 SELECT * -->
    <sql id="Base_Column_List">
        id, title, content, source_url, author_id, heat_score, status, created_at, updated_at
    </sql>

    <!-- 1) 参考样例：按主键查 -->
    <select id="selectById" resultType="com.nailong.gengdirection.post.entity.GengPost">
        SELECT <include refid="Base_Column_List"/>
        FROM geng_post
        WHERE id = #{id}
    </select>

