<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.nailong.gengdirection.tag.mapper.TagMapper">

    <!-- 查询所有标签 -->
    <select id="listAllTags" resultType="com.nailong.gengdirection.tag.entity.TagInfo">
        SELECT * FROM tag
    </select>

    <!-- 新增标签 -->
    <insert id="insertTag" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO tag(tag_name)
        VALUES (#{tagName})
    </insert>

    <!-- 给帖子打标签 -->
    <insert id="insertPostTag">
        INSERT INTO post_tag(post_id, tag_id)
        VALUES (#{postId}, #{tagId})
    </insert>

    <!-- 移除帖子标签 -->
    <delete id="deletePostTag">
        DELETE FROM post_tag
        WHERE post_id = #{postId} AND tag_id = #{tagId}
    </delete>

    <!-- 按标签ID分页查询关联的帖子ID列表 -->
    <select id="listPostIdsByTagId" resultType="java.lang.Long">
        SELECT post_id
        FROM post_tag
        WHERE tag_id = #{tagId}
            LIMIT #{offset}, #{pageSize}
    </select>

</mapper>